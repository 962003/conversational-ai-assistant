# Copy to backend/.env and fill in values.

# --- Gemini ---
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Paths (defaults are fine for local dev) ---
# KNOWLEDGE_BASE_DIR=../knowledge_base
# DATABASE_PATH=./data/analytics.db

# --- Retrieval ---
TOP_K=4

# --- Embeddings (vector retrieval) ---
# Retrieval uses vector embeddings when available, else TF-IDF keyword fallback.
EMBEDDINGS_ENABLED=true
EMBEDDING_MODEL=text-embedding-004
# Newer option: gemini-embedding-001

# Embedding/generation backend:
#   USE_VERTEX=false -> Gemini Developer API (uses GEMINI_API_KEY above)
#   USE_VERTEX=true  -> Vertex AI (uses Application Default Credentials)
USE_VERTEX=false
# Required when USE_VERTEX=true:
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# For Vertex AI auth, run `gcloud auth application-default login` locally, or set:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Dialogflow CX (route the demo through a real CX agent) ---
# Provision an agent with: python dialogflow/provision_agent.py ...
# Auth uses ADC (gcloud auth application-default login) or a service account.
DIALOGFLOW_PROJECT=
DIALOGFLOW_LOCATION=global
DIALOGFLOW_AGENT_ID=
DIALOGFLOW_LANGUAGE=en

# Confidence below this is treated as "low" → suggest human handoff.
CONFIDENCE_THRESHOLD=0.35

# --- Webhook security (optional shared secret with Dialogflow CX) ---
WEBHOOK_SECRET=

# --- CORS (comma-separated origins, or *) ---
CORS_ORIGINS=*
